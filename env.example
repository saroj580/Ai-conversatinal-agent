## Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chatbb?schema=public"

## Better Auth
BETTER_AUTH_SECRET="replace-with-long-random-string"

## AI
OPENAI_API_KEY="sk-..."

## App base URL (used to build OAuth callback URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

## Google Calendar OAuth
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GOOGLE_OAUTH_STATE_SECRET="replace-with-long-random-string"

## Encryption key for storing app credentials in DB (base64 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_CREDENTIAL_ENCRYPTION_KEY="..."


